# ── SPARQL Endpoint Authentication ──
# These env vars are referenced via ${VAR_NAME} in semantic store configs.
# The buildStore() function resolves them from process.env automatically.
#
# Copy this file to .env and fill in your credentials:
#   cp src/24-semantic-rag/.env.example src/24-semantic-rag/.env

# Wikidata public endpoint (no auth needed, but User-Agent recommended)
SPARQL_WIKIDATA_URL=https://query.wikidata.org/sparql

# Stardog / RDF4J / GraphDB endpoints (requires authentication)
ENTERPRISE_SPARQL_URL=https://stardog.internal.example.com/sparql
ENTERPRISE_API_KEY=sk-your-api-key-here

# Amazon Neptune (IAM auth or X-Api-Key)
NEPTUNE_HOST=db-neptune-1.region.neptune.amazonaws.com
NEPTUNE_API_KEY=your-neptune-api-key

# Local file paths
RESEARCH_DATA_PATH=./data/research.ttl
HR_DATA_PATH=./data/employees.ttl
